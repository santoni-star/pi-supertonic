# === TTS (Supertonic) ===
# Supertonic TTS вбудований напряму — окремий сервер не потрібен
TTS_VOICE=F1
TTS_LANG=uk
TTS_SPEED=1.05
TTS_STEPS=8
TTS_FORMAT=mp3

# === STT (Groq Whisper — для realtime) ===
# Google STT (Chrome) не потребує ключа
GROQ_API_KEY=gsk_...
GROQ_STT_MODEL=whisper-large-v3

# === Server ===
HOST=0.0.0.0
PORT=8888
