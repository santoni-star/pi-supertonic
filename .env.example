# === LLM ===
LLM_PROVIDER=groq       # groq | openai | ollama
GROQ_API_KEY=gsk_...
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

# === STT ===
# Google STT використовується через Web Speech API в Chrome (без ключа)
# Groq STT — для реального часу або якщо не Chrome
GROQ_STT_MODEL=whisper-large-v3

# === TTS ===
TTS_API_URL=http://127.0.0.1:8765
TTS_VOICE=F1
TTS_LANG=uk
TTS_SPEED=1.05
TTS_STEPS=8
TTS_FORMAT=mp3

# === Server ===
HOST=0.0.0.0
PORT=8888
